# MQTT Broker Configuration
MQTT_HOST=localhost
MQTT_PORT=1883
# EMQX credentials that were previously working
MQTT_USERNAME=openclaw
MQTT_PASSWORD=kingsware@123
MQTT_CLIENT_ID=opencode-agent
MQTT_CLEAN_SESSION=true
MQTT_CONNECT_TIMEOUT=60000
MQTT_RECONNECT_PERIOD=5000

# MQTT v5.0 User Properties
MQTT_USER_PROPERTIES_NAME=coder
MQTT_USER_PROPERTIES_DESCRIPTION=负责各种代码编写及编码问题处理
MQTT_USER_PROPERTIES_EMOJI=🤖

# Private Chat Topic
MQTT_PRIVATE_CHAT_TOPIC=opencode-agent/inbound

# OpenCode Configuration
# For local OpenCode instance without authentication, leave blank or use a dummy key
OPENCODE_API_KEY=

OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_MODEL=tencent/glm-5.1
OPENCODE_WORKSPACE_DIR=/opt/workspace