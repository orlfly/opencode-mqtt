# MQTT Broker Configuration
# -------------------------
# MQTT broker host address
MQTT_HOST=localhost

# MQTT broker port (default: 1883 for non-secure, 8883 for secure)
MQTT_PORT=1883

# MQTT username (leave empty for anonymous connections)
MQTT_USERNAME=

# MQTT password (leave empty for anonymous connections)
MQTT_PASSWORD=

# Unique client identifier for this service
MQTT_CLIENT_ID=nestjs-mqtt-service

# Whether to use a clean session (true/false)
MQTT_CLEAN_SESSION=true

# Connection timeout in milliseconds
MQTT_CONNECT_TIMEOUT=60000

# Reconnection period in milliseconds
MQTT_RECONNECT_PERIOD=5000

# MQTT v5.0 User Properties
# Name of the client service
MQTT_USER_PROPERTIES_NAME=nestjs-mqtt-service

# Description of the client service
MQTT_USER_PROPERTIES_DESCRIPTION=NestJS MQTT Microservice Client

# Emoji representing the client service
MQTT_USER_PROPERTIES_EMOJI=🤖

# Private chat topic pattern to subscribe to
MQTT_PRIVATE_CHAT_TOPIC=private/chat/+

# OpenCode Configuration
# API Key for OpenCode service (set this only if your OpenCode instance requires authentication)
# For local instances without authentication, leave empty
OPENCODE_API_KEY=

# Base URL for OpenCode API (default: http://localhost:3000)
OPENCODE_BASE_URL=http://localhost:3000

# Model to use with OpenCode (default: gpt-4)
OPENCODE_MODEL=gpt-4

# Example of a secure connection:
# MQTT_HOST=mqtt.example.com
# MQTT_PORT=8883
# MQTT_USERNAME=myusername
# MQTT_PASSWORD=mypassword
# MQTT_CLIENT_ID=production-mqtt-service